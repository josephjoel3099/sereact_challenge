{
  "name": "sereact_challenge",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--network=host",
    "--ipc=host",
    "--privileged"
  ],
  "containerEnv": {
    "ROS_DOMAIN_ID": "0",
    "RMW_IMPLEMENTATION": "rmw_cyclonedds_cpp"
  },
  "remoteUser": "ros"
}
